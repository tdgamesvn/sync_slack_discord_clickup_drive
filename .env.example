# Environment Variables Template
# Copy this file to .env and fill in the values

# Server
PORT=3000
NODE_ENV=production
JWT_SECRET=                    # REQUIRED — strong random secret for JWT signing
APP_URL=http://localhost:3000  # Base URL of the app (used for CORS, OAuth redirect)

# NocoDB
NOCODB_URL=                    # e.g. https://nocodb.example.com
NOCODB_API_TOKEN=              # NocoDB API token
NOCODB_BASE_ID=                # NocoDB Base/Project ID

# ClickUp
CLICKUP_API_TOKEN=             # ClickUp API token
CLICKUP_WORKSPACE_ID=          # ClickUp Workspace ID
CLICKUP_WEBHOOK_SECRET=        # ClickUp Webhook signing secret

# Slack
SLACK_BOT_TOKEN=               # xoxb-... Slack Bot token
SLACK_SIGNING_SECRET=          # Slack app signing secret

# Discord
DISCORD_BOT_TOKEN=             # Discord bot token

# Google Drive
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./GOOGLE_SERVICE_ACCOUNT_KEY.json
GOOGLE_CLIENT_ID=              # Google OAuth Client ID
GOOGLE_CLIENT_SECRET=          # Google OAuth Client Secret
GOOGLE_REDIRECT_URI=           # OAuth callback URL (auto-derived from APP_URL if empty)
